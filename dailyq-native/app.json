{
  "expo": {
    "name": "DailyQ",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9418d4f1-3d4b-4492-b37d-6a31b50ed5da",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "slug": "dailyq",
    "version": "1.0.2",
    "orientation": "portrait",
    "scheme": "dailyq",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-apple-authentication",
      "expo-font",
      "expo-router",
      [
        "expo-build-properties",
        {
          "buildReactNativeFromSource": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#8B5CF6",
          "iosDisplayInForeground": true,
          "sounds": []
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.tjade.dailyq",
      "supportsTablet": false,
      "associatedDomains": [],
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationsUsageDescription": "DailyQ sends a daily reminder so you don't miss your question."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.tjade.dailyq",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "dailyq",
              "host": "reset-password"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "9418d4f1-3d4b-4492-b37d-6a31b50ed5da"
      }
    }
  }
}
